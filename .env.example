APP_ENV=development
HOST=0.0.0.0
PORT=8080

DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=yoyo_booking
DB_SSLMODE=disable
AUTO_MIGRATE=true

CORS_ALLOWED_ORIGINS=http://localhost:5173
TRUSTED_PROXIES=
REQUEST_BODY_LIMIT_BYTES=10485760
RATE_LIMIT_PER_MINUTE=120
LOGIN_RATE_LIMIT_PER_HOUR=10
CONTACT_RATE_LIMIT_PER_HOUR=20
PAYMENT_RATE_LIMIT_PER_HOUR=30

JWT_SECRET=replace_with_a_long_random_secret
JWT_ACCESS_TOKEN_TTL=24h
BCRYPT_COST=12

ADMIN_NAME=YOYO Super Admin
ADMIN_EMAIL=admin@yoyofun.local
ADMIN_PASSWORD=change-this-password

RAZORPAY_ENABLED=true
RAZORPAY_KEY_ID=rzp_test_replace_with_key_id
RAZORPAY_KEY_SECRET=replace_with_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_webhook_secret

UPLOADS_STORAGE=r2
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=5242880
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
